@model ContactManagerPro.Models.Contact

@{
    ViewData["Title"] = "Add Contact";
}

<style>
    .form-page {
        max-width: 700px;
        margin: 0 auto;
    }

    .form-page-header {
        margin-bottom: var(--spacing-2xl);
    }

    .form-page-title {
        font-size: 28px;
        font-weight: 600;
        color: var(--gray-900);
        margin-bottom: var(--spacing-sm);
    }

    .form-page-subtitle {
        font-size: 14px;
        color: var(--gray-500);
    }

    .form-card {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: 8px;
        padding: var(--spacing-2xl);
        box-shadow: var(--shadow-sm);
    }

    .form-section {
        margin-bottom: var(--spacing-2xl);
    }

    .form-section:last-child {
        margin-bottom: 0;
    }

    .form-section-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--gray-600);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: var(--spacing-lg);
        padding-bottom: var(--spacing-lg);
        border-bottom: 1px solid var(--gray-200);
    }

    .form-group {
        margin-bottom: var(--spacing-lg);
    }

    .form-group.required .form-label::after {
        content: ' *';
        color: var(--danger);
    }

    .form-actions {
        display: flex;
        gap: var(--spacing-md);
        margin-top: var(--spacing-2xl);
        padding-top: var(--spacing-xl);
        border-top: 1px solid var(--gray-200);
    }

    .form-actions .btn {
        flex: 1;
        justify-content: center;
    }

    @@media (max-width: 768px) {
        .form-card {
            padding: var(--spacing-lg);
        }

        .form-actions {
            flex-direction: column;
        }

        .form-actions .btn {
            flex: none;
        }
    }
</style>

<div class="form-page">
    <div class="form-page-header">
        <h1 class="form-page-title">Add Contact</h1>
        <p class="form-page-subtitle">Create a new contact and add them to your network.</p>
    </div>

    <div class="form-card">
        <form asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- Personal Information -->
            <div class="form-section">
                <h3 class="form-section-title">Personal Information</h3>

                <div class="form-row">
                    <div class="form-group required">
                        <label asp-for="Prenom" class="form-label"></label>
                        <input asp-for="Prenom" class="form-control" placeholder="John" />
                        <span asp-validation-for="Prenom" class="form-error"></span>
                    </div>

                    <div class="form-group required">
                        <label asp-for="Nom" class="form-label"></label>
                        <input asp-for="Nom" class="form-control" placeholder="Doe" />
                        <span asp-validation-for="Nom" class="form-error"></span>
                    </div>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="form-section">
                <h3 class="form-section-title">Contact Information</h3>

                <div class="form-group required">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com" />
                    <span asp-validation-for="Email" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Telephone" class="form-label">Phone</label>
                    <input asp-for="Telephone" type="tel" class="form-control" placeholder="+1 (555) 000-0000" />
                    <span asp-validation-for="Telephone" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Adresse" class="form-label">Address</label>
                    <input asp-for="Adresse" class="form-control" placeholder="123 Main St" />
                    <span asp-validation-for="Adresse" class="form-error"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Ville" class="form-label">City</label>
                        <input asp-for="Ville" class="form-control" placeholder="New York" />
                        <span asp-validation-for="Ville" class="form-error"></span>
                    </div>
                </div>
            </div>

            <!-- Professional Information -->
            <div class="form-section">
                <h3 class="form-section-title">Professional Information</h3>

                <div class="form-group">
                    <label asp-for="Entreprise" class="form-label">Company</label>
                    <input asp-for="Entreprise" class="form-control" placeholder="Acme Corp" />
                    <span asp-validation-for="Entreprise" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Profession" class="form-label">Job Title</label>
                    <input asp-for="Profession" class="form-control" placeholder="Product Manager" />
                    <span asp-validation-for="Profession" class="form-error"></span>
                </div>
            </div>

            <!-- Additional Information -->
            <div class="form-section">
                <h3 class="form-section-title">Additional Information</h3>

                <div class="form-group">
                    <label asp-for="Notes" class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" placeholder="Add any notes about this contact..."></textarea>
                    <span asp-validation-for="Notes" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhotoUrl" class="form-label">Photo URL</label>
                    <input asp-for="PhotoUrl" class="form-control" placeholder="https://example.com/photo.jpg" />
                    <div class="form-hint">Full URL to the contact's profile photo</div>
                    <span asp-validation-for="PhotoUrl" class="form-error"></span>
                </div>

                <div class="form-group" style="display: flex; align-items: center; gap: var(--spacing-md);">
                    <input asp-for="Favori" type="checkbox" id="favoriteCheckbox" />
                    <label for="favoriteCheckbox" style="margin: 0; font-weight: 500; cursor: pointer;">
                        Mark as favorite
                    </label>
                </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Add Contact
                </button>
                <a href="@Url.Action("Index", "Contacts")" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

