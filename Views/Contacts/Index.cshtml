@model List<ContactManagerPro.Models.Contact>

@{
	ViewData["Title"] = "Contacts";
}

<style>
	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--spacing-xl);
		gap: var(--spacing-lg);
	}

	.page-title {
		margin: 0;
		font-size: 28px;
		font-weight: 600;
		color: var(--gray-900);
	}

	.page-actions {
		display: flex;
		gap: var(--spacing-md);
	}

	.filter-bar {
		background: white;
		border: 1px solid var(--gray-200);
		border-radius: 8px;
		padding: var(--spacing-lg);
		margin-bottom: var(--spacing-lg);
		box-shadow: var(--shadow-sm);
	}

	.filter-group {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: var(--spacing-md);
		margin-bottom: var(--spacing-md);
	}

	.filter-group:last-child {
		margin-bottom: 0;
	}

	.filter-actions {
		display: flex;
		gap: var(--spacing-md);
		margin-top: var(--spacing-lg);
		justify-content: flex-end;
	}

	.contacts-grid {
		--grid-cols: name, title, company, email, actions;
		grid-template-areas: "name title company email actions";
	}

	@@media (max-width: 1024px) {
		.contacts-grid {
			--grid-cols: name, company, actions;
		}

		.grid-header {
			grid-template-columns: 2fr 2fr 1fr;
		}

		.grid-row {
			grid-template-columns: 2fr 2fr 1fr;
		}

		.contact-subtitle {
			display: none;
		}
	}

	@@media (max-width: 768px) {
		.page-header {
			flex-direction: column;
			align-items: flex-start;
		}

		.page-actions {
			width: 100%;
		}

		.filter-bar {
			padding: var(--spacing-md);
		}

		.filter-group {
			grid-template-columns: 1fr;
		}
	}

	.contact-email {
		color: var(--primary);
		text-decoration: none;
		font-size: 13px;
	}

	.contact-email:hover {
		text-decoration: underline;
	}

	.btn-icon-action {
		padding: 0.375rem;
		width: 28px;
		height: 28px;
		border-radius: 4px;
		background-color: var(--gray-100);
		border: none;
		color: var(--gray-600);
		cursor: pointer;
		transition: all var(--transition-base);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.btn-icon-action:hover {
		background-color: var(--primary);
		color: white;
	}

	.favorite-btn {
		background: none !important;
		border: none !important;
		padding: 0.375rem !important;
		width: 28px !important;
		height: 28px !important;
		color: var(--gray-300) !important;
		font-size: 16px !important;
		cursor: pointer;
		transition: color var(--transition-base);
	}

	.favorite-btn.active {
		color: var(--warning) !important;
	}

	.favorite-btn:hover {
		color: var(--warning) !important;
	}
</style>

<div class="page-header">
	<h1 class="page-title">Contacts</h1>
	<div class="page-actions">
		<a asp-controller="Contacts" asp-action="Create" class="btn btn-primary">
			<i class="bi bi-plus-lg"></i> Add Contact
		</a>
	</div>
</div>
<div class="filter-bar">
	<input type="text"
		   id="searchInput"
		   class="form-control"
		   placeholder="Search contacts, company, email, city..." />
</div>

<!-- Data Grid -->
@if (Model.Any())
{
	<div class="data-grid">
		<div class="grid-header" style="grid-template-columns: 2fr 1fr 1.5fr 1.5fr 180px;">
			<div>Name</div>
			<div>Job Title</div>
			<div>Company</div>
			<div>Email</div>
			<div style="text-align: center;">Actions</div>
		</div>

		@foreach (var contact in Model)
		{
			<div class="grid-row contact-row" style="grid-template-columns: 2fr 1fr 1.5fr 1.5fr 180px;">
				<!-- Contact Name -->
				<div class="contact-cell">
					<div class="contact-avatar">
						@contact.Prenom.First().ToString().ToUpper()
					</div>
					<div class="contact-info">
						<div class="contact-name">@contact.Prenom @contact.Nom</div>
						@if (!string.IsNullOrEmpty(contact.Ville))
						{
							<div class="contact-subtitle">
								<i class="bi bi-geo-alt"></i> @contact.Ville
							</div>
						}
					</div>
				</div>

				<!-- Job Title -->
				<div>
					<div class="contact-name">@(string.IsNullOrEmpty(contact.Profession) ? "-" : contact.Profession)</div>
				</div>

				<!-- Company -->
				<div>
					<div class="contact-name">@(contact.Company?.Name ?? "-")</div>
				</div>

				<!-- Email -->
				<div>
					<a href="mailto:@contact.Email" class="contact-email">@contact.Email</a>
				</div>

				<!-- Actions -->
				<div class="grid-actions">
					<span class="favorite-btn @(contact.Favori ? "active" : "")" title="@(contact.Favori ? "Favorite" : "Not favorite")">
						<i class="bi bi-star-fill"></i>
					</span>

					<a asp-controller="Contacts" asp-action="Details" asp-route-id="@contact.Id" class="btn-icon-action" title="View">
						<i class="bi bi-eye"></i>
					</a>

					<a asp-controller="Contacts" asp-action="Edit" asp-route-id="@contact.Id" class="btn-icon-action" title="Edit">
						<i class="bi bi-pencil"></i>
					</a>

					<a asp-controller="Contacts" asp-action="Delete" asp-route-id="@contact.Id" class="btn-icon-action" title="Delete" 
					   onclick="return confirm('Are you sure?')">
						<i class="bi bi-trash"></i>
					</a>
				</div>
			</div>
		}
	</div>
}
else
{
	<div class="empty-state">
		<div class="empty-state-icon">
			<i class="bi bi-inbox"></i>
		</div>
		<h3 class="empty-state-title">No contacts found</h3>
		<p class="empty-state-text">Start by creating your first contact.</p>
		<a asp-controller="Contacts" asp-action="Create" class="btn btn-primary">
			<i class="bi bi-plus-lg"></i> Add Contact
		</a>
	</div>
}


@section Scripts {

	<script>

		const searchInput = document.getElementById("searchInput");

		searchInput.addEventListener("keyup", function () {

			let value = this.value.toLowerCase();

			let rows = document.querySelectorAll(".contact-row");


			rows.forEach(row => {

				let content = row.innerText.toLowerCase();

				if(content.includes(value))
				{
					row.style.display = "";
				}
				else
				{
					row.style.display = "none";
				}

			});

		});


		@if (TempData["SuccessMessage"] != null)
		{
				<text>
						showToast('@TempData["SuccessMessage"]', 'success');
				</text>
		}

	</script>

}