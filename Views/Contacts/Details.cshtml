@model ContactManagerPro.Models.Contact

@{
    ViewData["Title"] = "Contact Details";
}

<style>
    .detail-page {
        max-width: 1000px;
        margin: 0 auto;
    }

    .detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--spacing-2xl);
        gap: var(--spacing-lg);
    }

    .detail-title {
        font-size: 28px;
        font-weight: 600;
        color: var(--gray-900);
    }

    .detail-actions {
        display: flex;
        gap: var(--spacing-md);
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: var(--spacing-xl);
    }

    .profile-card {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: 8px;
        padding: var(--spacing-2xl);
        box-shadow: var(--shadow-sm);
        text-align: center;
    }

    .profile-avatar-section {
        margin-bottom: var(--spacing-xl);
        padding-bottom: var(--spacing-xl);
        border-bottom: 1px solid var(--gray-200);
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 8px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 48px;
        margin: 0 auto var(--spacing-lg);
        overflow: hidden;
    }

    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-name {
        font-size: 20px;
        font-weight: 600;
        color: var(--gray-900);
        margin-bottom: var(--spacing-sm);
    }

    .profile-title {
        color: var(--primary);
        font-weight: 500;
        margin-bottom: var(--spacing-xs);
    }

    .profile-company {
        color: var(--gray-500);
        font-size: 13px;
    }

    .profile-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--spacing-md);
        margin-top: var(--spacing-lg);
        padding-top: var(--spacing-lg);
        border-top: 1px solid var(--gray-200);
    }

    .profile-stat {
        text-align: center;
    }

    .stat-value {
        font-size: 18px;
        font-weight: 600;
        color: var(--gray-900);
    }

    .stat-label {
        font-size: 12px;
        color: var(--gray-500);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .detail-content {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-xl);
    }

    .info-card {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: 8px;
        box-shadow: var(--shadow-sm);
    }

    .info-card-header {
        padding: var(--spacing-lg);
        border-bottom: 1px solid var(--gray-200);
        background-color: var(--gray-50);
        font-weight: 600;
        color: var(--gray-900);
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-card-body {
        padding: var(--spacing-lg);
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--spacing-lg);
    }

    .info-item {
        display: flex;
        flex-direction: column;
    }

    .info-label {
        font-size: 12px;
        color: var(--gray-500);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: var(--spacing-sm);
        font-weight: 600;
    }

    .info-value {
        font-size: 14px;
        color: var(--gray-900);
        font-weight: 500;
    }

    .info-value.empty {
        color: var(--gray-400);
        font-style: italic;
    }

    .info-value a {
        color: var(--primary);
        text-decoration: none;
    }

    .info-value a:hover {
        text-decoration: underline;
    }

    .notes-section {
        padding: var(--spacing-lg);
        background-color: var(--gray-50);
    }

    .notes-text {
        color: var(--gray-700);
        line-height: 1.6;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .detail-footer {
        display: flex;
        gap: var(--spacing-md);
        margin-top: var(--spacing-2xl);
    }

    .detail-footer .btn {
        flex: 1;
        justify-content: center;
    }

    @@media (max-width: 768px) {
        .detail-grid {
            grid-template-columns: 1fr;
        }

        .detail-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .detail-actions {
            width: 100%;
            flex-wrap: wrap;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .detail-footer {
            flex-direction: column;
        }

        .detail-footer .btn {
            flex: none;
        }
    }
</style>

<div class="detail-page">
    <!-- Header -->
    <div class="detail-header">
        <h1 class="detail-title">@Model.Prenom @Model.Nom</h1>
        <div class="detail-actions">
            <a href="@Url.Action("Edit", "Contacts", new { id = Model.Id })" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a href="@Url.Action("Delete", "Contacts", new { id = Model.Id })" class="btn btn-secondary" 
               onclick="return confirm('Are you sure you want to delete this contact?')">
                <i class="bi bi-trash"></i> Delete
            </a>
            <a href="@Url.Action("Index", "Contacts")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="detail-grid">
        <!-- Profile Card -->
        <div class="profile-card">
            <div class="profile-avatar-section">
                <div class="profile-avatar">
                    @Model.Prenom.First().ToString().ToUpper()
                </div>
                <div class="profile-name">@Model.Prenom @Model.Nom</div>
                @if (!string.IsNullOrEmpty(Model.Profession))
                {
                    <div class="profile-title">@Model.Profession</div>
                }
                @if (!string.IsNullOrEmpty(Model.Entreprise))
                {
                    <div class="profile-company">@Model.Entreprise</div>
                }
            </div>

            <div class="profile-stats">
                <div class="profile-stat">
                    <div class="stat-value">
                        @if (Model.Favori)
                        {
                            <i class="bi bi-star-fill" style="color: var(--warning);"></i>
                        }
                        else
                        {
                            <i class="bi bi-star" style="color: var(--gray-400);"></i>
                        }
                    </div>
                    <div class="stat-label">Favorite</div>
                </div>
                <div class="profile-stat">
                    <div class="stat-value">@Model.DateCreation.ToString("MMM dd")</div>
                    <div class="stat-label">Added</div>
                </div>
            </div>
        </div>

        <!-- Details -->
        <div class="detail-content">
            <!-- Contact Information -->
            <div class="info-card">
                <div class="info-card-header">
                    <i class="bi bi-envelope"></i> Contact Information
                </div>
                <div class="info-card-body">
                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">Email</span>
                            <a href="mailto:@Model.Email" class="info-value">@Model.Email</a>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Phone</span>
                            <span class="info-value @(string.IsNullOrEmpty(Model.Telephone) ? "empty" : "")">
                                @if (!string.IsNullOrEmpty(Model.Telephone))
                                {
                                    <a href="tel:@Model.Telephone">@Model.Telephone</a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Address</span>
                            <span class="info-value @(string.IsNullOrEmpty(Model.Adresse) ? "empty" : "")">
                                @if (!string.IsNullOrEmpty(Model.Adresse))
                                {
                                    @Model.Adresse
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">City</span>
                            <span class="info-value @(string.IsNullOrEmpty(Model.Ville) ? "empty" : "")">
                                @if (!string.IsNullOrEmpty(Model.Ville))
                                {
                                    @Model.Ville
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Professional Information -->
            <div class="info-card">
                <div class="info-card-header">
                    <i class="bi bi-briefcase"></i> Professional Information
                </div>
                <div class="info-card-body">
                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">Company</span>
                            <span class="info-value @(string.IsNullOrEmpty(Model.Entreprise) ? "empty" : "")">
                                @if (!string.IsNullOrEmpty(Model.Entreprise))
                                {
                                    @Model.Entreprise
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Job Title</span>
                            <span class="info-value @(string.IsNullOrEmpty(Model.Profession) ? "empty" : "")">
                                @if (!string.IsNullOrEmpty(Model.Profession))
                                {
                                    @Model.Profession
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Notes -->
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="info-card">
                    <div class="info-card-header">
                        <i class="bi bi-sticky"></i> Notes
                    </div>
                    <div class="info-card-body">
                        <div class="notes-section">
                            <div class="notes-text">@Model.Notes</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Actions -->
    <div class="detail-footer">
        <a href="@Url.Action("Edit", "Contacts", new { id = Model.Id })" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Edit Contact
        </a>
        <a href="@Url.Action("Index", "Contacts")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Contacts
        </a>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }
    </script>
}

