<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Contactify</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/crm-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="crm-layout">
    <!-- Sidebar Navigation -->
    <aside class="crm-sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <div class="logo-icon">
                    <i class="bi bi-person-rolodex"></i>
                </div>
                <span class="logo-text">Contactify</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <a href="@Url.Action("Index", "Home")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="bi bi-house-door"></i>
                <span>Dashboard</span>
            </a>
            <a href="@Url.Action("Index", "Contacts")" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Contacts" ? "active" : "")">
                <i class="bi bi-person-lines-fill"></i>
                <span>Contacts</span>
            </a>
            <a href="#" class="nav-item">
                <i class="bi bi-star"></i>
                <span>Favorites</span>
            </a>
            <a href="#" class="nav-item">
                <i class="bi bi-building"></i>
                <span>Companies</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="#" class="nav-item">
                <i class="bi bi-gear"></i>
                <span>Settings</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="crm-main">
        <!-- Top Navigation Bar -->
        <header class="crm-header">
            <div class="header-left">
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Search contacts...">
                </div>
            </div>

            <div class="header-right">
                <button class="header-icon-btn">
                    <i class="bi bi-bell"></i>
                </button>
                <div class="user-menu">
                    <button class="user-avatar">
                        <img src="https://via.placeholder.com/32" alt="User">
                    </button>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="crm-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function showToast(message, type = 'info', duration = 3000) {
            console.log(message, type);
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

