@model ContactManagerPro.Models.Company

@{
	ViewData["Title"] = "Edit Company";
}

<style>
	.form-page {
		max-width: 700px;
		margin: 0 auto;
	}

	.form-page-header {
		margin-bottom: var(--spacing-2xl);
	}

	.form-page-title {
		font-size: 28px;
		font-weight: 600;
		color: var(--gray-900);
		margin-bottom: var(--spacing-sm);
	}

	.form-page-subtitle {
		font-size: 14px;
		color: var(--gray-500);
	}

	.form-card {
		background: white;
		border: 1px solid var(--gray-200);
		border-radius: 8px;
		padding: var(--spacing-2xl);
		box-shadow: var(--shadow-sm);
	}

	.form-section {
		margin-bottom: var(--spacing-2xl);
	}

	.form-section:last-child {
		margin-bottom: 0;
	}

	.form-section-title {
		font-size: 14px;
		font-weight: 600;
		color: var(--gray-600);
		text-transform: uppercase;
		letter-spacing: 0.5px;
		margin-bottom: var(--spacing-lg);
		padding-bottom: var(--spacing-lg);
		border-bottom: 1px solid var(--gray-200);
	}

	.form-group {
		margin-bottom: var(--spacing-lg);
	}

	.form-group.required .form-label::after {
		content: ' *';
		color: var(--danger);
	}

	.form-actions {
		display: flex;
		gap: var(--spacing-md);
		margin-top: var(--spacing-2xl);
		padding-top: var(--spacing-xl);
		border-top: 1px solid var(--gray-200);
	}

	.form-actions .btn {
		flex: 1;
		justify-content: center;
	}

	@@media (max-width: 768px) {
		.form-card {
			padding: var(--spacing-lg);
		}

		.form-actions {
			flex-direction: column;
		}

		.form-actions .btn {
			flex: none;
		}
	}
</style>

<div class="form-page">
	<div class="form-page-header">
		<h1 class="form-page-title">Edit Company</h1>
		<p class="form-page-subtitle">Update company information.</p>
	</div>

	<div class="form-card">
		<form asp-action="Edit" method="post" novalidate>
			<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
			<input type="hidden" asp-for="Id" />

			<!-- Company Information -->
			<div class="form-section">
				<h3 class="form-section-title">Company Information</h3>

				<div class="form-group required">
					<label asp-for="Name" class="form-label"></label>
					<input asp-for="Name" class="form-control" />
					<span asp-validation-for="Name" class="form-error"></span>
				</div>

				<div class="form-group">
					<label asp-for="Industry" class="form-label"></label>
					<input asp-for="Industry" class="form-control" />
					<span asp-validation-for="Industry" class="form-error"></span>
				</div>

				<div class="form-group">
					<label asp-for="Website" class="form-label"></label>
					<input asp-for="Website" type="url" class="form-control" />
					<span asp-validation-for="Website" class="form-error"></span>
				</div>

				<div class="form-group">
					<label asp-for="Address" class="form-label"></label>
					<input asp-for="Address" class="form-control" />
					<span asp-validation-for="Address" class="form-error"></span>
				</div>

				<div class="form-group">
					<label class="form-label">Created</label>
					<input asp-for="CreatedAt" class="form-control" readonly />
				</div>
			</div>

			<!-- Actions -->
			<div class="form-actions">
				<button type="submit" class="btn btn-primary">
					<i class="bi bi-check-lg"></i> Save Changes
				</button>
				<a asp-controller="Companies" asp-action="Index" class="btn btn-secondary">
					<i class="bi bi-x-lg"></i> Cancel
				</a>
			</div>
		</form>
	</div>
</div>

@section Scripts {
	@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
