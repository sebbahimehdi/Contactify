@model ContactManagerPro.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-header {
        margin-bottom: var(--spacing-2xl);
    }

    .dashboard-title {
        font-size: 28px;
        font-weight: 600;
        color: var(--gray-900);
        margin-bottom: var(--spacing-sm);
    }

    .dashboard-subtitle {
        font-size: 14px;
        color: var(--gray-500);
    }

    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--spacing-lg);
        margin-bottom: var(--spacing-2xl);
    }

    .section-title {
        font-size: 16px;
        font-weight: 600;
        color: var(--gray-900);
        margin-bottom: var(--spacing-lg);
        margin-top: var(--spacing-2xl);
    }

    .section-title:first-child {
        margin-top: 0;
    }

    .activity-list {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
    }

    .activity-item {
        padding: var(--spacing-lg);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        gap: var(--spacing-md);
        align-items: flex-start;
        transition: background-color var(--transition-base);
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    .activity-item:hover {
        background-color: var(--gray-50);
    }

    .activity-icon {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
        background-color: var(--info-light);
        color: var(--primary);
    }

    .activity-content {
        flex: 1;
        min-width: 0;
    }

    .activity-title {
        font-weight: 500;
        color: var(--gray-900);
        margin-bottom: 2px;
    }

    .activity-description {
        font-size: 13px;
        color: var(--gray-500);
    }

    .activity-time {
        font-size: 12px;
        color: var(--gray-400);
        margin-top: var(--spacing-xs);
    }

    @@media (max-width: 768px) {
        .kpi-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .dashboard-title {
            font-size: 24px;
        }
    }

    @@media (max-width: 480px) {
        .kpi-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-header">
    <h1 class="dashboard-title">Dashboard</h1>
    <p class="dashboard-subtitle">Welcome back. Here's an overview of your contacts.</p>
</div>

<!-- KPI Cards -->
<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-header">
            <div>
                <div class="kpi-label">Total Contacts</div>
                <div class="kpi-value">@Model.TotalContacts</div>
            </div>
            <div class="kpi-icon primary">
                <i class="bi bi-person-fill"></i>
            </div>
        </div>
        <div class="kpi-change positive">
            <i class="bi bi-arrow-up-short"></i>
            <span>12% from last month</span>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-header">
            <div>
                <div class="kpi-label">Favorite Contacts</div>
                <div class="kpi-value">@Model.FavoriteContacts</div>
            </div>
            <div class="kpi-icon success">
                <i class="bi bi-star-fill"></i>
            </div>
        </div>
        <div class="kpi-change positive">
            <i class="bi bi-arrow-up-short"></i>
            <span>5 new this week</span>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-header">
            <div>
                <div class="kpi-label">Companies</div>
                <div class="kpi-value">@Model.CompaniesCount</div>
            </div>
            <div class="kpi-icon warning">
                <i class="bi bi-building"></i>
            </div>
        </div>
        <div class="kpi-change positive">
            <i class="bi bi-arrow-up-short"></i>
            <span>3 new companies</span>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-header">
            <div>
                <div class="kpi-label">Categories</div>
                <div class="kpi-value">@Model.CategoriesCount</div>
            </div>
            <div class="kpi-icon primary">
                <i class="bi bi-tag"></i>
            </div>
        </div>
        <div class="kpi-change positive">
            <i class="bi bi-arrow-up-short"></i>
            <span>Contact organization</span>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-header">
            <div>
                <div class="kpi-label">Notes</div>
                <div class="kpi-value">@Model.NotesCount</div>
            </div>
            <div class="kpi-icon primary">
                <i class="bi bi-sticky"></i>
            </div>
        </div>
        <div class="kpi-change positive">
            <i class="bi bi-arrow-up-short"></i>
            <span>Activity tracked</span>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-header">
            <div>
                <div class="kpi-label">Cities</div>
                <div class="kpi-value">@Model.CitiesCount</div>
            </div>
            <div class="kpi-icon primary">
                <i class="bi bi-geo-alt-fill"></i>
            </div>
        </div>
        <div class="kpi-change positive">
            <i class="bi bi-arrow-up-short"></i>
            <span>Spanning 2 countries</span>
        </div>
    </div>
</div>

<!-- Recent Activity -->
@if (Model.RecentContacts.Any())
{
    <h2 class="section-title">Recent Contacts</h2>
    <div class="activity-list">
        @foreach (var contact in Model.RecentContacts.Take(5))
        {
            <div class="activity-item">
                <div class="activity-icon">
                    <i class="bi bi-person-plus"></i>
                </div>
                <div class="activity-content">
                    <div class="activity-title">
                        <a asp-controller="Contacts" asp-action="Details" asp-route-id="@contact.Id" style="color: var(--primary); text-decoration: none;">
                            @contact.Prenom @contact.Nom
                        </a>
                        <span style="font-weight: 400; color: var(--gray-500);">was added</span>
                    </div>
                    <div class="activity-description">
                        @if (contact.Company != null)
                        {
                            <span>@contact.Company.Name</span>
                        }
                        @if (!string.IsNullOrEmpty(contact.Profession))
                        {
                            <span> · @contact.Profession</span>
                        }
                    </div>
                    <div class="activity-time">
                        @contact.DateCreation.ToString("MMM dd, yyyy")
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state" style="margin-top: var(--spacing-2xl);">
        <div class="empty-state-icon">
            <i class="bi bi-inbox"></i>
        </div>
        <h3 class="empty-state-title">No contacts yet</h3>
        <p class="empty-state-text">Start by creating your first contact to get started.</p>
        <a asp-controller="Contacts" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Contact
        </a>
    </div>
}


