@model ContactManagerPro.Models.ContactIndexViewModel

@{
	ViewData["Title"] = "Contacts";
}

<style>
	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--spacing-xl);
		gap: var(--spacing-lg);
	}

	.page-title {
		margin: 0;
		font-size: 28px;
		font-weight: 600;
		color: var(--gray-900);
	}

	.page-actions {
		display: flex;
		gap: var(--spacing-md);
	}

	.filter-bar {
		background: white;
		border: 1px solid var(--gray-200);
		border-radius: 8px;
		padding: var(--spacing-lg);
		margin-bottom: var(--spacing-lg);
		box-shadow: var(--shadow-sm);
	}

	.filter-group {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: var(--spacing-md);
		margin-bottom: var(--spacing-md);
	}

	.filter-group:last-child {
		margin-bottom: 0;
	}

	.filter-actions {
		display: flex;
		gap: var(--spacing-md);
		margin-top: var(--spacing-lg);
		justify-content: flex-end;
	}

	.contacts-grid {
		--grid-cols: name, title, company, email, actions;
		grid-template-areas: "name title company email actions";
	}

	@@media (max-width: 1024px) {
		.contacts-grid {
			--grid-cols: name, company, actions;
		}

		.grid-header {
			grid-template-columns: 2fr 2fr 1fr;
		}

		.grid-row {
			grid-template-columns: 2fr 2fr 1fr;
		}

		.contact-subtitle {
			display: none;
		}
	}

	@@media (max-width: 768px) {
		.page-header {
			flex-direction: column;
			align-items: flex-start;
		}

		.page-actions {
			width: 100%;
		}

		.filter-bar {
			padding: var(--spacing-md);
		}

		.filter-group {
			grid-template-columns: 1fr;
		}
	}

	.contact-email {
		color: var(--primary);
		text-decoration: none;
		font-size: 13px;
	}

	.contact-email:hover {
		text-decoration: underline;
	}

	.btn-icon-action {
		padding: 0.375rem;
		width: 28px;
		height: 28px;
		border-radius: 4px;
		background-color: var(--gray-100);
		border: none;
		color: var(--gray-600);
		cursor: pointer;
		transition: all var(--transition-base);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.btn-icon-action:hover {
		background-color: var(--primary);
		color: white;
	}

	.favorite-btn {
		background: none !important;
		border: none !important;
		padding: 0.375rem !important;
		width: 28px !important;
		height: 28px !important;
		color: var(--gray-300) !important;
		font-size: 16px !important;
		cursor: pointer;
		transition: color var(--transition-base);
	}

	.favorite-btn.active {
		color: var(--warning) !important;
	}

	.favorite-btn:hover {
		color: var(--warning) !important;
	}
</style>

<div class="page-header">
	<h1 class="page-title">Contacts</h1>
	<div class="page-actions">
		<a href="@Url.Action("Create", "Contacts")" class="btn btn-primary">
			<i class="bi bi-plus-lg"></i> Add Contact
		</a>
	</div>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
	<form method="get" asp-action="Index">
		<div class="filter-group">
			<div class="form-group" style="margin-bottom: 0;">
				<label class="form-label">Search</label>
				<div class="search-box" style="background: transparent; border: 1px solid var(--gray-300); padding: 0 var(--spacing-md); height: 36px;">
					<i class="bi bi-search"></i>
					<input type="text" name="searchString" placeholder="Search by name, email, company..." 
						   value="@Model.SearchString" class="form-control" style="border: none; padding: 0 var(--spacing-md); background: transparent;">
				</div>
			</div>

			<div class="form-group" style="margin-bottom: 0;">
				<label class="form-label">Sort by</label>
				<select name="sortBy" class="form-select">
					<option value="name" selected="@(Model.SortBy == "name")">Name (A-Z)</option>
					<option value="name-desc" selected="@(Model.SortBy == "name-desc")">Name (Z-A)</option>
					<option value="date-desc" selected="@(Model.SortBy == "date-desc")">Recently Added</option>
					<option value="company" selected="@(Model.SortBy == "company")">Company</option>
				</select>
			</div>

			<div class="form-group" style="margin-bottom: 0;">
				<label class="form-label">Filter</label>
				<select name="favorites" class="form-select">
					<option value="">All Contacts</option>
					<option value="true" selected="@(Model.IsFavoritesFilter)">Favorites Only</option>
				</select>
			</div>
		</div>

		<div class="filter-actions">
			<button type="submit" class="btn btn-primary btn-sm">
				<i class="bi bi-funnel"></i> Filter
			</button>
			<a href="@Url.Action("Index", "Contacts")" class="btn btn-secondary btn-sm">
				<i class="bi bi-arrow-clockwise"></i> Reset
			</a>
		</div>
	</form>
</div>

<!-- Data Grid -->
@if (Model.Contacts.Any())
{
	<div class="data-grid">
		<div class="grid-header" style="grid-template-columns: 2fr 1fr 1.5fr 1.5fr 180px;">
			<div>Name</div>
			<div>Job Title</div>
			<div>Company</div>
			<div>Email</div>
			<div style="text-align: center;">Actions</div>
		</div>

		@foreach (var contact in Model.Contacts)
		{
			<div class="grid-row" style="grid-template-columns: 2fr 1fr 1.5fr 1.5fr 180px;">
				<!-- Contact Name -->
				<div class="contact-cell">
					<div class="contact-avatar">
						@contact.Prenom.First().ToString().ToUpper()
					</div>
					<div class="contact-info">
						<div class="contact-name">@contact.Prenom @contact.Nom</div>
						@if (!string.IsNullOrEmpty(contact.Ville))
						{
							<div class="contact-subtitle">
								<i class="bi bi-geo-alt"></i> @contact.Ville
							</div>
						}
					</div>
				</div>

				<!-- Job Title -->
				<div>
					<div class="contact-name">@(string.IsNullOrEmpty(contact.Profession) ? "-" : contact.Profession)</div>
				</div>

				<!-- Company -->
				<div>
					<div class="contact-name">@(string.IsNullOrEmpty(contact.Entreprise) ? "-" : contact.Entreprise)</div>
				</div>

				<!-- Email -->
				<div>
					<a href="mailto:@contact.Email" class="contact-email">@contact.Email</a>
				</div>

				<!-- Actions -->
				<div class="grid-actions">
					<form method="post" asp-action="ToggleFavorite" asp-route-id="@contact.Id" style="display: inline;">
						<button type="submit" class="favorite-btn @(contact.Favori ? "active" : "")" title="@(contact.Favori ? "Remove from favorites" : "Add to favorites")">
							<i class="bi bi-star-fill"></i>
						</button>
					</form>

					<a href="@Url.Action("Details", "Contacts", new { id = contact.Id })" class="btn-icon-action" title="View">
						<i class="bi bi-eye"></i>
					</a>

					<a href="@Url.Action("Edit", "Contacts", new { id = contact.Id })" class="btn-icon-action" title="Edit">
						<i class="bi bi-pencil"></i>
					</a>

					<a href="@Url.Action("Delete", "Contacts", new { id = contact.Id })" class="btn-icon-action" title="Delete" 
					   onclick="return confirm('Are you sure?')">
						<i class="bi bi-trash"></i>
					</a>
				</div>
			</div>
		}
	</div>
}
else
{
	<div class="empty-state">
		<div class="empty-state-icon">
			<i class="bi bi-inbox"></i>
		</div>
		<h3 class="empty-state-title">No contacts found</h3>
		<p class="empty-state-text">@(Model.IsFavoritesFilter ? "You don't have any favorite contacts yet." : "Start by creating your first contact.")</p>
		<a href="@Url.Action("Create", "Contacts")" class="btn btn-primary">
			<i class="bi bi-plus-lg"></i> Add Contact
		</a>
	</div>
}

@section Scripts {
	<script>
		@if (TempData["SuccessMessage"] != null)
		{
			<text>
				showToast('@TempData["SuccessMessage"]', 'success');
			</text>
		}
	</script>
}
