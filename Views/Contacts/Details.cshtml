@model ContactManagerPro.Models.Contact

@{
	ViewData["Title"] = $"{Model.Prenom} {Model.Nom}";
}

<style>
	.details-page {
		max-width: 1000px;
		margin: 0 auto;
	}

	.details-header {
		background: white;
		border: 1px solid var(--gray-200);
		border-radius: 8px;
		padding: var(--spacing-2xl);
		margin-bottom: var(--spacing-2xl);
		box-shadow: var(--shadow-sm);
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: var(--spacing-2xl);
		align-items: start;
	}

	.details-avatar {
		width: 100px;
		height: 100px;
		background: linear-gradient(135deg, var(--primary), var(--secondary));
		color: white;
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 42px;
		font-weight: 600;
	}

	.details-info h1 {
		font-size: 28px;
		font-weight: 600;
		color: var(--gray-900);
		margin-bottom: var(--spacing-sm);
	}

	.details-info p {
		font-size: 14px;
		color: var(--gray-500);
		margin: 0;
	}

	.details-actions {
		display: flex;
		gap: var(--spacing-md);
		flex-direction: column;
	}

	.details-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: var(--spacing-lg);
	}

	.details-card {
		background: white;
		border: 1px solid var(--gray-200);
		border-radius: 8px;
		padding: var(--spacing-lg);
		box-shadow: var(--shadow-sm);
	}

	.details-card h3 {
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
		color: var(--gray-600);
		margin-bottom: var(--spacing-lg);
		padding-bottom: var(--spacing-lg);
		border-bottom: 1px solid var(--gray-200);
	}

	.detail-item {
		display: flex;
		justify-content: space-between;
		align-items: start;
		margin-bottom: var(--spacing-md);
		padding-bottom: var(--spacing-md);
		border-bottom: 1px solid var(--gray-100);
	}

	.detail-item:last-child {
		margin-bottom: 0;
		padding-bottom: 0;
		border-bottom: none;
	}

	.detail-label {
		font-size: 13px;
		color: var(--gray-500);
		font-weight: 500;
	}

	.detail-value {
		font-size: 14px;
		color: var(--gray-900);
		font-weight: 600;
	}

	.detail-value.empty {
		color: var(--gray-400);
		font-style: italic;
	}

	.notes-section {
		background: white;
		border: 1px solid var(--gray-200);
		border-radius: 8px;
		padding: var(--spacing-lg);
		box-shadow: var(--shadow-sm);
	}

	.notes-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--spacing-lg);
		padding-bottom: var(--spacing-lg);
		border-bottom: 1px solid var(--gray-200);
	}

	.notes-header h3 {
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
		color: var(--gray-600);
		margin: 0;
	}

	.note-item {
		background: var(--gray-50);
		border: 1px solid var(--gray-200);
		border-radius: 6px;
		padding: var(--spacing-md);
		margin-bottom: var(--spacing-md);
	}

	.note-item:last-child {
		margin-bottom: 0;
	}

	.note-title {
		font-weight: 600;
		color: var(--gray-900);
		margin-bottom: var(--spacing-xs);
	}

	.note-content {
		font-size: 13px;
		color: var(--gray-600);
		margin-bottom: var(--spacing-sm);
		word-wrap: break-word;
	}

	.note-date {
		font-size: 12px;
		color: var(--gray-400);
	}

	.empty-state {
		text-align: center;
		padding: var(--spacing-2xl);
		color: var(--gray-400);
	}

	.empty-state i {
		font-size: 32px;
		margin-bottom: var(--spacing-md);
		display: block;
	}

	@@media (max-width: 768px) {
		.details-header {
			grid-template-columns: 1fr;
			gap: var(--spacing-lg);
		}

		.details-actions {
			flex-direction: row;
		}

		.details-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<div class="details-page">
	<!-- Header -->
	<div class="details-header">
		<div class="details-avatar">
			@Model.Prenom.First().ToString().ToUpper()
		</div>
		<div class="details-info">
			<h1>@Model.Prenom @Model.Nom</h1>
			@if (!string.IsNullOrEmpty(Model.Profession))
			{
				<p>@Model.Profession</p>
			}
			@if (!string.IsNullOrEmpty(Model.Ville))
			{
				<p><i class="bi bi-geo-alt"></i> @Model.Ville</p>
			}
		</div>
		<div class="details-actions">
			<a asp-controller="Contacts" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
				<i class="bi bi-pencil"></i> Edit
			</a>
			<a asp-controller="Contacts" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
				<i class="bi bi-trash"></i> Delete
			</a>
			<a asp-controller="Contacts" asp-action="Index" class="btn btn-secondary">
				<i class="bi bi-arrow-left"></i> Back
			</a>
		</div>
	</div>

	<!-- Details Grid -->
	<div class="details-grid">
		<!-- Contact Information -->
		<div class="details-card">
			<h3>Contact Information</h3>
			<div class="detail-item">
				<span class="detail-label">Email</span>
				<a href="mailto:@Model.Email" class="detail-value">@Model.Email</a>
			</div>
			<div class="detail-item">
				<span class="detail-label">Phone</span>
				<span class="detail-value @(string.IsNullOrEmpty(Model.Telephone) ? "empty" : "")">
					@(string.IsNullOrEmpty(Model.Telephone) ? "Not provided" : Model.Telephone)
				</span>
			</div>
			<div class="detail-item">
				<span class="detail-label">Address</span>
				<span class="detail-value @(string.IsNullOrEmpty(Model.Adresse) ? "empty" : "")">
					@(string.IsNullOrEmpty(Model.Adresse) ? "Not provided" : Model.Adresse)
				</span>
			</div>
			<div class="detail-item">
				<span class="detail-label">City</span>
				<span class="detail-value @(string.IsNullOrEmpty(Model.Ville) ? "empty" : "")">
					@(string.IsNullOrEmpty(Model.Ville) ? "Not provided" : Model.Ville)
				</span>
			</div>
		</div>

		<!-- Professional Information -->
		<div class="details-card">
			<h3>Professional Information</h3>
			<div class="detail-item">
				<span class="detail-label">Company</span>
				@if (Model.Company != null)
				{
					<a asp-controller="Companies" asp-action="Details" asp-route-id="@Model.Company.Id" class="detail-value">
						@Model.Company.Name
					</a>
				}
				else
				{
					<span class="detail-value empty">Not assigned</span>
				}
			</div>
			<div class="detail-item">
				<span class="detail-label">Category</span>
				@if (Model.Category != null)
				{
					<a asp-controller="Categories" asp-action="Details" asp-route-id="@Model.Category.Id" class="detail-value">
						@Model.Category.Name
					</a>
				}
				else
				{
					<span class="detail-value empty">Not assigned</span>
				}
			</div>
			<div class="detail-item">
				<span class="detail-label">Job Title</span>
				<span class="detail-value @(string.IsNullOrEmpty(Model.Profession) ? "empty" : "")">
					@(string.IsNullOrEmpty(Model.Profession) ? "Not provided" : Model.Profession)
				</span>
			</div>
			<div class="detail-item">
				<span class="detail-label">Favorite</span>
				<span class="detail-value">
					@if (Model.Favori)
					{
						<text><i class="bi bi-star-fill" style="color: var(--warning);"></i> Yes</text>
					}
					else
					{
						<text><i class="bi bi-star"></i> No</text>
					}
				</span>
			</div>
		</div>

		<!-- Timeline Information -->
		<div class="details-card">
			<h3>Timeline</h3>
			<div class="detail-item">
				<span class="detail-label">Created</span>
				<span class="detail-value">@Model.DateCreation.ToString("MMM d, yyyy")</span>
			</div>
		</div>
	</div>

	<!-- Notes Section -->
	<div class="notes-section" style="margin-top: var(--spacing-lg);">
		<div class="notes-header">
			<h3>Notes</h3>
			<a asp-controller="Notes" asp-action="Create" asp-route-contactId="@Model.Id" class="btn btn-sm btn-primary">
				<i class="bi bi-plus-lg"></i> Add Note
			</a>
		</div>

		@if (Model.Notes.Any())
		{
			@foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt))
			{
				<div class="note-item">
					<div class="note-title">@note.Title</div>
					<div class="note-content">@note.Content</div>
					<div class="note-date">
						<i class="bi bi-clock"></i> @note.CreatedAt.ToString("MMM d, yyyy 'at' hh:mm tt")
						<a asp-controller="Notes" asp-action="Edit" asp-route-id="@note.Id" class="ms-2" style="text-decoration: underline; color: var(--primary);">Edit</a>
						<a asp-controller="Notes" asp-action="Delete" asp-route-id="@note.Id" class="ms-2" style="text-decoration: underline; color: var(--danger);">Delete</a>
					</div>
				</div>
			}
		}
		else
		{
			<div class="empty-state">
				<i class="bi bi-sticky"></i>
				<p>No notes yet. Add one to keep track of important information about this contact.</p>
			</div>
		}
	</div>
</div>

@section Scripts {
	<script>
		@if (TempData["SuccessMessage"] != null)
		{
			<text>
				showToast('@TempData["SuccessMessage"]', 'success');
			</text>
		}
	</script>
}
