@model ContactManagerPro.Models.Note

@{
	ViewData["Title"] = "Edit Note";
}

<style>
	.form-page {
		max-width: 700px;
		margin: 0 auto;
	}

	.form-page-header {
		margin-bottom: var(--spacing-2xl);
	}

	.form-page-title {
		font-size: 28px;
		font-weight: 600;
		color: var(--gray-900);
		margin-bottom: var(--spacing-sm);
	}

	.form-page-subtitle {
		font-size: 14px;
		color: var(--gray-500);
	}

	.form-card {
		background: white;
		border: 1px solid var(--gray-200);
		border-radius: 8px;
		padding: var(--spacing-2xl);
		box-shadow: var(--shadow-sm);
	}

	.form-section {
		margin-bottom: var(--spacing-2xl);
	}

	.form-section:last-child {
		margin-bottom: 0;
	}

	.form-section-title {
		font-size: 14px;
		font-weight: 600;
		color: var(--gray-600);
		text-transform: uppercase;
		letter-spacing: 0.5px;
		margin-bottom: var(--spacing-lg);
		padding-bottom: var(--spacing-lg);
		border-bottom: 1px solid var(--gray-200);
	}

	.form-group {
		margin-bottom: var(--spacing-lg);
	}

	.form-group.required .form-label::after {
		content: ' *';
		color: var(--danger);
	}

	.form-actions {
		display: flex;
		gap: var(--spacing-md);
		margin-top: var(--spacing-2xl);
		padding-top: var(--spacing-xl);
		border-top: 1px solid var(--gray-200);
	}

	.form-actions .btn {
		flex: 1;
		justify-content: center;
	}

	@@media (max-width: 768px) {
		.form-card {
			padding: var(--spacing-lg);
		}

		.form-actions {
			flex-direction: column;
		}

		.form-actions .btn {
			flex: none;
		}
	}
</style>

<div class="form-page">
	<div class="form-page-header">
		<h1 class="form-page-title">Edit Note</h1>
		<p class="form-page-subtitle">Update note information.</p>
	</div>

	<div class="form-card">
		<form asp-action="Edit" method="post" novalidate>
			<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
			<input type="hidden" asp-for="Id" />

			<!-- Note Information -->
			<div class="form-section">
				<h3 class="form-section-title">Note Information</h3>

				<div class="form-group required">
					<label for="ContactId" class="form-label">Contact</label>
					<select id="ContactId" name="ContactId" class="form-control">
						<option value="">-- Select a contact --</option>
						@{
							var contacts = ViewData["Contacts"] as List<ContactManagerPro.Models.Contact>;
							if (contacts != null)
							{
								@foreach (var contact in contacts)
								{
									<option value="@contact.Id" selected="@(Model.ContactId == contact.Id)">
										@contact.Prenom @contact.Nom
									</option>
								}
							}
						}
					</select>
					<span asp-validation-for="ContactId" class="form-error"></span>
				</div>

				<div class="form-group required">
					<label asp-for="Title" class="form-label"></label>
					<input asp-for="Title" class="form-control" />
					<span asp-validation-for="Title" class="form-error"></span>
				</div>

				<div class="form-group required">
					<label asp-for="Content" class="form-label"></label>
					<textarea asp-for="Content" class="form-control" rows="8"></textarea>
					<span asp-validation-for="Content" class="form-error"></span>
				</div>

				<div class="form-group">
					<label class="form-label">Created</label>
					<input asp-for="CreatedAt" class="form-control" readonly />
				</div>
			</div>

			<!-- Actions -->
			<div class="form-actions">
				<button type="submit" class="btn btn-primary">
					<i class="bi bi-check-lg"></i> Save Changes
				</button>
				<a asp-controller="Notes" asp-action="Index" class="btn btn-secondary">
					<i class="bi bi-x-lg"></i> Cancel
				</a>
			</div>
		</form>
	</div>
</div>

@section Scripts {
	@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
