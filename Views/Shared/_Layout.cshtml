<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Contactify</title>
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/crm-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="crm-layout">
    <!-- Sidebar Navigation -->
    <aside class="crm-sidebar">
        <div class="sidebar-header">
            <a asp-controller="Home" asp-action="Index" class="sidebar-logo">
                <img src="~/images/contactify-logo.svg" alt="Contactify Logo" class="logo-image" />
                <span class="logo-text">Contactify</span>
            </a>
        </div>

        <nav class="sidebar-nav">
            <a asp-controller="Home" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="bi bi-house-door"></i>
                <span>Dashboard</span>
            </a>
            <a asp-controller="Contacts" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Contacts" && ViewContext.RouteData.Values["Action"]?.ToString() != "Favorites" ? "active" : "")">
                <i class="bi bi-person-lines-fill"></i>
                <span>Contacts</span>
            </a>
            <a asp-controller="Contacts" asp-action="Favorites" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Favorites" ? "active" : "")">
                <i class="bi bi-star"></i>
                <span>Favorites</span>
            </a>
            <a asp-controller="Companies" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Companies" ? "active" : "")">
                <i class="bi bi-building"></i>
                <span>Companies</span>
            </a>
            <a asp-controller="Categories" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? "active" : "")">
                <i class="bi bi-tag"></i>
                <span>Categories</span>
            </a>
            <a asp-controller="Notes" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Notes" ? "active" : "")">
                <i class="bi bi-sticky"></i>
                <span>Notes</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="#" class="nav-item">
                <i class="bi bi-gear"></i>
                <span>Settings</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="crm-main">
        <!-- Top Navigation Bar -->
        <header class="crm-header">
        </header>

        <!-- Page Content -->
        <main class="crm-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function showToast(message, type = 'info', duration = 3000) {
            console.log(message, type);
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                showToast('@TempData["SuccessMessage"]', 'success');
            </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

