@model ContactManagerPro.Models.Category

@{
	ViewData["Title"] = "Delete Category";
}

<style>
	.delete-page {
		max-width: 500px;
		margin: 0 auto;
	}

	.delete-card {
		background: white;
		border: 1px solid var(--gray-200);
		border-radius: 8px;
		padding: var(--spacing-2xl);
		box-shadow: var(--shadow-sm);
		text-align: center;
	}

	.delete-icon {
		font-size: 48px;
		color: var(--danger);
		margin-bottom: var(--spacing-lg);
	}

	.delete-title {
		font-size: 20px;
		font-weight: 600;
		color: var(--gray-900);
		margin-bottom: var(--spacing-md);
	}

	.delete-description {
		font-size: 14px;
		color: var(--gray-600);
		margin-bottom: var(--spacing-2xl);
		line-height: 1.6;
	}

	.category-name-confirm {
		background: var(--gray-50);
		border: 1px solid var(--gray-200);
		border-radius: 6px;
		padding: var(--spacing-md);
		margin-bottom: var(--spacing-2xl);
	}

	.category-name-confirm strong {
		color: var(--gray-900);
	}

	.delete-actions {
		display: flex;
		gap: var(--spacing-md);
		justify-content: center;
	}

	.delete-actions .btn {
		flex: 1;
		max-width: 200px;
	}
</style>

<div class="delete-page">
	<div class="delete-card">
		<div class="delete-icon">
			<i class="bi bi-exclamation-triangle"></i>
		</div>
		<h1 class="delete-title">Delete Category</h1>
		<p class="delete-description">
			Are you sure you want to delete this category? Associated contacts will not be deleted but will lose their category assignment.
		</p>
		<div class="category-name-confirm">
			<strong>@Model.Name</strong><br>
			<small style="color: var(--gray-500);">@(Model.Contacts.Count) related contact(s)</small>
		</div>
		<div class="delete-actions">
			<form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
				<button type="submit" class="btn btn-danger">
					<i class="bi bi-trash"></i> Delete
				</button>
			</form>
			<a asp-controller="Categories" asp-action="Index" class="btn btn-secondary">
				<i class="bi bi-x-lg"></i> Cancel
			</a>
		</div>
	</div>
</div>
